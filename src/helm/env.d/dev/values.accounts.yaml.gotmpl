      -----END RSA PRIVATE KEY-----
    LOGIN_REDIRECT_URL: https://accounts.127.0.0.1.nip.io
    LOGIN_REDIRECT_URL_FAILURE: https://accounts.127.0.0.1.nip.io
    LOGOUT_REDIRECT_URL: https://accounts.127.0.0.1.nip.io
    DB_HOST: dev-backend-postgres
    DB_NAME:
      secretKeyRef:
        name: dev-backend-postgres
        key: database
    DB_USER:
      secretKeyRef:
        name: dev-backend-postgres
        key: username
    DB_PASSWORD:
      secretKeyRef:
        name: dev-backend-postgres
        key: password
    DB_PORT: 5432
    REDIS_URL: redis://user:pass@dev-backend-redis:6379/1
    DJANGO_CELERY_BROKER_URL: redis://user:pass@dev-backend-redis:6379/1
    AWS_S3_ENDPOINT_URL: http://dev-backend-minio.accounts.svc.cluster.local:9000
    AWS_S3_ACCESS_KEY_ID: dinum
    AWS_S3_SECRET_ACCESS_KEY: password
    AWS_STORAGE_BUCKET_NAME: accounts-media-storage
    STORAGES_STATICFILES_BACKEND: django.contrib.staticfiles.storage.StaticFilesStorage
    CACHES_KEY_PREFIX: "{{ now | unixEpoch }}"
  django:
    envVars:
      WEB_CONCURRENCY: 1
      DB_PSYCOPG_POOL_MIN_SIZE: 10

  migrate:
    command:
      - "/bin/sh"
      - "-c"
      - |
        while ! python manage.py check --database default > /dev/null 2>&1
        do
          echo "Database not ready"
          sleep 2
        done

        echo "Database is ready"

        python manage.py migrate --no-input
    restartPolicy: Never

  # command:
  #   - uvicorn
  #   - --app-dir=/app
  #   - --host=0.0.0.0
  #   - --timeout-graceful-shutdown=300
  #   - --limit-max-requests=20000
  #   - --lifespan=off
  #   - --reload
  #   - "accounts.asgi:application"

  createsuperuser:
    command:
      - "/bin/sh"
      - "-c"
      - |
        while ! python manage.py check --database default > /dev/null 2>&1
        do
          echo "Database not ready"
          sleep 2
        done

        echo "Database is ready"
        python manage.py createsuperuser --email admin@example.com --password admin
    restartPolicy: Never

  themeCustomization:
    enabled: true
    file_content: {{ readFile "./configuration/theme/demo.json" }}

  # Extra volume mounts to manage our local custom CA and avoid to set ssl_verify: false
  extraVolumeMounts:
    - name: certs
      mountPath: /cert/cacert.pem
      subPath: cacert.pem

  # Extra volumes to manage our local custom CA and avoid to set ssl_verify: false
  extraVolumes:
    - name: certs
      configMap:
        name: certifi
        items:
        - key: cacert.pem
          path: cacert.pem

frontend:
  envVars:
    PORT: 8080
    NEXT_PUBLIC_API_ORIGIN: https://accounts.127.0.0.1.nip.io

  replicas: 1
  command:
    - yarn
    - dev

  image:
    repository: localhost:5001/accounts-frontend
    pullPolicy: Always
    tag: "latest"

  securityContext:
    runAsNonRoot: false

ingress:
  enabled: true
  host: accounts.127.0.0.1.nip.io
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: 20m

ingressAdmin:
  enabled: true
  host: accounts.127.0.0.1.nip.io

posthog:
  ingress:
    enabled: false

  ingressAssets:
    enabled: false

ingressMedia:
  enabled: true
  host: accounts.127.0.0.1.nip.io

  annotations:
    nginx.ingress.kubernetes.io/auth-url: https://accounts.127.0.0.1.nip.io/api/v1.0/documents/media-auth/
    nginx.ingress.kubernetes.io/auth-response-headers: "Authorization, X-Amz-Date, X-Amz-Content-SHA256"
    nginx.ingress.kubernetes.io/upstream-vhost: dev-backend-minio.accounts.svc.cluster.local:9000
    nginx.ingress.kubernetes.io/rewrite-target: /accounts-media-storage/$1

serviceMedia:
  host: dev-backend-minio.accounts.svc.cluster.local
  port: 9000
