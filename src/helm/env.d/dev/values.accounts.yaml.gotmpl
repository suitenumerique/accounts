djangoSecretKey: &djangoSecretKey "lkjsdlushdgfkfjslkdfjslkdjfslkdjf"
djangoSuperUserEmail: admin@example.com
djangoSuperUserPass: admin
oidc:
    clientId: accounts
    clientSecret: ThisIsAnExampleKeyForDevPurposeOnly

image:
  repository: localhost:5001/accounts-backend
  pullPolicy: Always
  tag: "latest"

backend:
  replicas: 1
  envVars:
    COLLABORATION_SERVER_SECRET: my-secret
    DJANGO_CSRF_TRUSTED_ORIGINS: https://accounts.127.0.0.1.nip.io
    DJANGO_CONFIGURATION: Production
    DJANGO_ALLOWED_HOSTS: accounts.127.0.0.1.nip.io
    DJANGO_SERVER_TO_SERVER_API_TOKENS: secret-api-key
    DJANGO_SECRET_KEY: *djangoSecretKey
    DJANGO_SETTINGS_MODULE: accounts.settings
    DJANGO_SUPERUSER_PASSWORD: admin
    DJANGO_EMAIL_BRAND_NAME: "La Suite Numérique"
    DJANGO_EMAIL_HOST: "mailcatcher"
    DJANGO_EMAIL_LOGO_IMG: https://accounts.127.0.0.1.nip.io/assets/logo-suite-numerique.png
    DJANGO_EMAIL_PORT: 1025
    DJANGO_EMAIL_URL_APP: https://accounts.127.0.0.1.nip.io
    DJANGO_EMAIL_USE_SSL: False
    FRONTEND_SILENT_LOGIN_ENABLED: True
    LOGGING_LEVEL_HANDLERS_CONSOLE: ERROR
    LOGGING_LEVEL_LOGGERS_ROOT: INFO
    LOGGING_LEVEL_LOGGERS_APP: INFO
    OIDC_USERINFO_SHORTNAME_FIELD: "first_name"
    OIDC_USERINFO_FULLNAME_FIELDS: "name"
    OIDC_OP_JWKS_ENDPOINT: https://accounts-keycloak.127.0.0.1.nip.io/realms/accounts/protocol/openid-connect/certs
    OIDC_OP_AUTHORIZATION_ENDPOINT: https://accounts-keycloak.127.0.0.1.nip.io/realms/accounts/protocol/openid-connect/auth
    OIDC_OP_TOKEN_ENDPOINT: https://accounts-keycloak.127.0.0.1.nip.io/realms/accounts/protocol/openid-connect/token
    OIDC_OP_USER_ENDPOINT: https://accounts-keycloak.127.0.0.1.nip.io/realms/accounts/protocol/openid-connect/userinfo
    OIDC_OP_LOGOUT_ENDPOINT: https://accounts-keycloak.127.0.0.1.nip.io/realms/accounts/protocol/openid-connect/logout
    OIDC_REDIRECT_ALLOWED_HOSTS: "accounts.127.0.0.1.nip.io"
    OIDC_RP_CLIENT_ID: accounts
    OIDC_RP_CLIENT_SECRET: ThisIsAnExampleKeyForDevPurposeOnly
    OIDC_RP_SIGN_ALGO: RS256
    OIDC_RP_SCOPES: "openid email profile"
    OAUTH2_PROVIDER_OIDC_RSA_PRIVATE_KEY: |-
