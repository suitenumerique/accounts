  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev --port 9900",
    "build": "next build",
    "build:ci": "cp .env.development .env.local && next build",
    "start": "npx -y serve@latest out",
    "lint": "eslint .",
    "build-theme": "cunningham -g css,scss,ts -o src/styles && mv src/styles/cunningham-tokens.scss src/styles/cunningham-tokens-sass.scss",
    "test": "echo \"No unit tests in this app — end-to-end tests live in apps/e2e\" && exit 0"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0",
    "yarn": "1.22.22"
  },
  "dependencies": {
    "@gouvfr-lasuite/cunningham-react": "4.3.1",
    "@gouvfr-lasuite/ui-kit": "0.27.0",
    "@tanstack/react-query": "5.101.2",
    "i18next": "26.3.6",
    "i18next-browser-languagedetector": "8.2.1",
    "next": "16.2.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.9",
    "sass": "1.101.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.6",
    "typescript": "7.0.2"
  }
}
