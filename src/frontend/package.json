{
  "name": "accounts",
  "version": "0.0.1",
  "private": true,
  "author": "DINUM",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0 <25.0.0",
    "yarn": "1.22.22"
  },
  "scripts": {
    "app:dev": "yarn workspace app-accounts run dev",
    "app:start": "yarn workspace app-accounts run start",
    "app:build": "yarn workspace app-accounts run build",
    "ci:build": "yarn workspace app-accounts run build:ci",
    "e2e:test": "yarn workspace app-e2e run test",
    "lint": "yarn workspace app-accounts run lint && yarn workspace app-e2e run lint",
    "test": "yarn workspace app-accounts run test",
    "i18n:extract": "yarn workspace packages-i18n run extract-translation",
    "i18n:deploy": "yarn workspace packages-i18n run format-deploy"
  },
  "packageManager": "yarn@1.22.22"
}
