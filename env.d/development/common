# Django
DJANGO_ALLOWED_HOSTS=*
DJANGO_SECRET_KEY=ThisIsAnExampleKeyForDevPurposeOnly
DJANGO_SETTINGS_MODULE=accounts.settings
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SALT_KEY=ThisIsAnExampleSaltForDevPurposeOnly

# Logging
# Set to DEBUG level for dev only
LOGGING_LEVEL_HANDLERS_CONSOLE=INFO
LOGGING_LEVEL_LOGGERS_ROOT=INFO
LOGGING_LEVEL_LOGGERS_APP=INFO

# Python
PYTHONPATH=/app

# accounts settings

# Mail
DJANGO_EMAIL_BRAND_NAME="La Suite Numérique"
DJANGO_EMAIL_HOST="mailcatcher"
DJANGO_EMAIL_LOGO_IMG="http://localhost:9900/assets/logo-suite-numerique.png"
DJANGO_EMAIL_PORT=1025
DJANGO_EMAIL_URL_APP="http://localhost:9900"

# Backend url
ACCOUNTS_BASE_URL="http://localhost:9901"

# Media
STORAGES_STATICFILES_BACKEND=django.contrib.staticfiles.storage.StaticFilesStorage
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_ACCESS_KEY_ID=accounts
AWS_S3_SECRET_ACCESS_KEY=password
MEDIA_BASE_URL=http://localhost:9903

# Authentication
LOGIN_REDIRECT_URL=http://localhost:9900
LOGOUT_REDIRECT_URL=http://localhost:9900

SOCIAL_AUTH_ALLOWED_REDIRECT_HOSTS="localhost:9900,localhost:9903"
SOCIAL_AUTH_PRO_CONNECT_KEY=accounts
SOCIAL_AUTH_PRO_CONNECT_SECRET=ThisIsAnExampleKeyForDevPurposeOnly
SOCIAL_AUTH_PRO_CONNECT_OIDC_ENDPOINT=http://nginx:9903/realms/accounts
# Override the endpoints URL called from the backend as they doesn't match the Keycloak hostname
SOCIAL_AUTH_PRO_CONNECT_ACCESS_TOKEN_URL=http://nginx:9903/realms/accounts/protocol/openid-connect/token
SOCIAL_AUTH_PRO_CONNECT_REVOKE_TOKEN_URL=http://nginx:9903/realms/accounts/protocol/openid-connect/revoke
SOCIAL_AUTH_PRO_CONNECT_USERINFO_URL=http://nginx:9903/realms/accounts/protocol/openid-connect/userinfo
SOCIAL_AUTH_PRO_CONNECT_JWKS_URI=http://nginx:9903/realms/accounts/protocol/openid-connect/certs
